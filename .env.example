# ============================================
# Telegram Bot Configuration
# ============================================
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=@your_bot_username
WEBSITE_URL=https://example.com/
SUPPORT_USERNAME_TG=@your_support_username
# ============================================
# Payment Provider: CrystalPay
# ============================================
PAYMENT_CRYSTALPAY_ID=your_crystalpay_id
PAYMENT_CRYSTALPAY_SECRET_ONE=your_secret_one
PAYMENT_CRYSTALPAY_SECRET_TWO=your_secret_two

# ============================================
# Payment Provider: Crypto Pay (CryptoBot)
# ============================================
PAYMENT_CRYPTOBOT_TOKEN=your_cryptobot_api_token

# DEDICATED_DEFAULT_MONTHLY_PRICE=50

# ============================================
# VMManager API
# ============================================
VMM_EMAIL=your_email@example.com
VMM_PASSWORD=your_vmm_password
VMM_ENDPOINT_URL=https://your-vmm-endpoint.com/

# ============================================
# Proxmox API (если VM_PROVIDER=proxmox)
# ============================================
# PROXMOX_BASE_URL=https://your-proxmox-host:8006
# PROXMOX_NODE=pve01
# PROXMOX_TOKEN_ID=api-user@pam!bot
# PROXMOX_TOKEN_SECRET=your-secret
# PROXMOX_STORAGE=local-lvm
# PROXMOX_BRIDGE=vmbr0
# PROXMOX_INSECURE_TLS=0
# PROXMOX_TEMPLATE_MAP={"ubuntu2204":102,"ubuntu2404":900}

# ============================================
# Prime Subscription
# ============================================
# PRIME_CHANNEL_INVITE=https://t.me/your_channel
# PRIME_CHANNEL_ID=-1001234567890
# PRIME_CHANNEL_USERNAME=your_channel_username

# ============================================
# Amper Domains API
# ============================================
AMPER_API_BASE_URL=https://amper.lat/api/v1
AMPER_API_TOKEN=your_amper_api_key
# AMPER_API_TIMEOUT_MS=8000

# ============================================
# CDN / proxy-service
# ============================================
# CDN_BASE_URL=https://your-proxy-service.com
# CDN_BOT_API_KEY=your-bot-api-key

# ============================================
# Domain Checker (опционально)
# ============================================
DOMAINR_TOKEN=your_domainr_token

# ============================================
# Webhook (опционально)
# ============================================
# IS_WEBHOOK=https://your-domain.com/webhook
# PORT_WEBHOOK=3002

# ADMIN_TELEGRAM_IDS=123456789
# CORS_ORIGIN=https://admin.example.com
# ADMIN_API_KEY=your-secret-admin-api-key

# ============================================
# Reseller API (optional)
# ============================================
# RESELLER_API_ENABLED=1
# RESELLER_API_PORT=3003
# RESELLER_API_KEYS_JSON={"partner_a":"replace-with-strong-secret-key"}

# ============================================
# Growth
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# Feature toggles
# ============================================
# SHOW_VPS_VDS_IN_MENUS=1

# ============================================
# Environment
# ============================================
NODE_ENV=production
